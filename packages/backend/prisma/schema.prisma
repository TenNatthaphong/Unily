generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  username         String            @unique
  email            String            @unique
  password         String?
  firstName        String
  lastName         String
  role             Role              @default(STUDENT)
  adminProfile     AdminProfile?
  professorProfile ProfessorProfile?
  studentProfile   StudentProfile?
}

model StudentProfile {
  userId      String           @id
  entryYear   Int
  department  String
  faculty     String
  gpax        Float            @default(0.00)
  year        Int
  records     AcademicRecord[]
  enrollments Enrollment[]
  user        User             @relation(fields: [userId], references: [id])
}

model ProfessorProfile {
  userId        String           @id
  facultyId     String           @default("04")
  deptId        String           @default("06")
  gradedRecords AcademicRecord[]
  user          User             @relation(fields: [userId], references: [id])
  sections      Section[]
}

model AdminProfile {
  userId String @id
  auditLog AuditLog[]
  user   User   @relation(fields: [userId], references: [id])
}

model Course {
  id                                            String             @id
  nameTh                                        String
  nameEn                                        String
  credits                                       Int
  category                                      CourseCategory     @default(CORE_COURSE)
  maxEntryYear                                  Int                @default(99)
  labHours                                      Int
  lectureHours                                  Int
  selfStudyHours                                Int
  isWildcard                                    Boolean            @default(false)
  deptId                                        String
  facultyId                                     String
  academicRecords                               AcademicRecord[]
  curriculumCourses                             CurriculumCourse[]
  Prerequisite_Prerequisite_courseIdToCourse    Prerequisite[]     @relation("Prerequisite_courseIdToCourse")
  Prerequisite_Prerequisite_preCourseIdToCourse Prerequisite[]     @relation("Prerequisite_preCourseIdToCourse")
  sections                                      Section[]
}

model Prerequisite {
  courseId                                String
  preCourseId                             String
  Course_Prerequisite_courseIdToCourse    Course @relation("Prerequisite_courseIdToCourse", fields: [courseId], references: [id])
  Course_Prerequisite_preCourseIdToCourse Course @relation("Prerequisite_preCourseIdToCourse", fields: [preCourseId], references: [id])

  @@id([courseId, preCourseId])
}

model Curriculum {
  id                String             @id @default(uuid())
  name              String
  facultyId         String
  deptId            String
  createdAt         DateTime           @default(now())
  description       String?
  updatedAt         DateTime           @updatedAt
  year              Int
  curriculumCourses CurriculumCourse[]
}

model CurriculumCourse {
  id           String     @id @default(uuid())
  curriculumId String
  courseId     String
  semester     Int
  year         Int
  positionX    Int
  positionY    Int
  course       Course     @relation(fields: [courseId], references: [id])
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])

  @@unique([curriculumId, courseId, semester])
}

model Section {
  id            String            @id @default(uuid())
  courseId      String
  sectionNo     Int
  capacity      Int
  enrolledCount Int               @default(0)
  semester      Int
  academicYear  Int
  professorId   String?
  enrollments   Enrollment[]
  schedules     Schedule[]
  course        Course            @relation(fields: [courseId], references: [id])
  professor     ProfessorProfile? @relation(fields: [professorId], references: [userId])
}

model Schedule {
  id        String  @id @default(uuid())
  sectionId String
  day       String
  startTime String
  endTime   String
  section   Section @relation(fields: [sectionId], references: [id])
}

model Enrollment {
  id        String           @id @default(uuid())
  studentId String
  sectionId String
  status    EnrollmentStatus @default(SUCCESS)
  dropDate  DateTime?
  createdAt DateTime         @default(now())
  section   Section          @relation(fields: [sectionId], references: [id])
  student   StudentProfile   @relation(fields: [studentId], references: [userId])
}

model AcademicRecord {
  id         String            @id @default(uuid())
  studentId  String
  courseId   String
  grade      String
  gradedById String?
  course     Course            @relation(fields: [courseId], references: [id])
  gradedBy   ProfessorProfile? @relation(fields: [gradedById], references: [userId])
  student    StudentProfile    @relation(fields: [studentId], references: [userId])
}

model SemesterConfig {
  id           String   @id @default(uuid())
  semester     Int
  academicYear Int
  regStart     DateTime
  regEnd       DateTime
  withdrawEnd  DateTime
  isCurrent    Boolean  @default(false)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model kv_store_105269f1 {
  key   String @id
  value Json

  @@index([key])
  @@index([key], map: "kv_store_105269f1_key_idx1")
  @@index([key], map: "kv_store_105269f1_key_idx2")
  @@index([key], map: "kv_store_105269f1_key_idx3")
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  adminName   String
  action      Action
  target      String   // เช่น "หลักสูตรวิทยาการคอมพิวเตอร์ 2567"
  createdAt   DateTime @default(now())
  admin       AdminProfile @relation(fields: [adminId], references: [userId])
}

// สำหรับข้อ 2: กิจกรรมและแบนเนอร์ประชาสัมพันธ์
model Event {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  startDate   DateTime
  endDate     DateTime
  category    String    // เช่น "ACADEMIC", "REGISTRATION", "ACTIVITY"
  bannerUrl   String?   // เก็บ Path ของรูปภาพ
  isPublished Boolean   @default(false)
  updatedBy   String
  updatedAt   DateTime  @updatedAt
}

enum Action {
  CREATE
  UPDATE
  DELETE
}

enum Role {
  STUDENT
  PROFESSOR
  ADMIN
}

enum CourseCategory {
  GENERAL_EDUCATION
  CORE_COURSE
  REQUIRED_COURSE
  MAJOR_ELECTIVE
  FREE_ELECTIVE
}

enum EnrollmentStatus {
  SUCCESS
  DROPPED
  WITHDRAWN
}
