generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String            @unique
  password         String
  firstName        String
  lastName         String
  role             Role              @default(STUDENT)
  status           UserStatus        @default(ACTIVE)
  adminProfile     AdminProfile?
  professorProfile ProfessorProfile?
  studentProfile   StudentProfile?
}

model StudentProfile {
  userId      String           @id @db.Uuid
  studentCode String           @unique
  facultyId   String           @db.Uuid
  deptId      String           @db.Uuid
  entryYear   Int
  year        Int
  gpax        Float            @default(0.00)
  status      StudentStatus    @default(STUDYING)
  records     AcademicRecord[]
  enrollments Enrollment[]
  department  Department       @relation(fields: [deptId], references: [id])
  faculty     Faculty          @relation(fields: [facultyId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
}

model ProfessorProfile {
  userId     String     @id @db.Uuid
  facultyId  String     @db.Uuid
  deptId     String     @db.Uuid
  department Department @relation(fields: [deptId], references: [id])
  faculty    Faculty    @relation(fields: [facultyId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  sections   Section[]
  gradedRecords AcademicRecord[]
}

model AdminProfile {
  userId String @id @db.Uuid
  auditLogs        AuditLog[]
  user   User   @relation(fields: [userId], references: [id])
}

model Faculty {
  id                                         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facultyCode                                String             @unique
  nameTh                                     String
  nameEn                                     String
  courses                                    Course[]
  curriculums                                Curriculum[]
  Department_Department_facultyCodeToFaculty Department[]       @relation("Department_facultyCodeToFaculty")
  departments                                Department[]
  professors                                 ProfessorProfile[]
  students                                   StudentProfile[]
}

model Department {
  id                                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facultyCode                             String
  deptCode                                String
  shortName                               String
  nameTh                                  String
  nameEn                                  String
  facultyId                               String             @db.Uuid
  courses                                 Course[]
  curriculums                             Curriculum[]
  Faculty_Department_facultyCodeToFaculty Faculty            @relation("Department_facultyCodeToFaculty", fields: [facultyCode], references: [facultyCode])
  faculty_id                              Faculty            @relation(fields: [facultyId], references: [id])
  professors                              ProfessorProfile[]
  students                                StudentProfile[]

  @@unique([facultyId, shortName])
  @@unique([facultyId, deptCode])
}

model Course {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseCode        String             @unique
  nameTh            String
  nameEn            String
  credits           Int
  labHours          Int
  lectureHours      Int
  selfStudyHours    Int
  category          CourseCategory     @default(CORE_COURSE)
  maxEntryYear      Int                @default(99)
  isWildcard        Boolean            @default(false)
  deptId            String             @db.Uuid
  facultyId         String             @db.Uuid
  academicRecords   AcademicRecord[]
  department        Department         @relation(fields: [deptId], references: [id])
  faculty           Faculty            @relation(fields: [facultyId], references: [id])
  curriculumCourses CurriculumCourse[]
  prerequisites     Prerequisite[]     @relation("CoursePrerequisites")
  requiredBy        Prerequisite[]     @relation("RequiredBy")
  sections          Section[]
}

model Prerequisite {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId         String @db.Uuid
  requiresCourseId String @db.Uuid
  course           Course @relation("CoursePrerequisites", fields: [courseId], references: [id])
  requiresCourse   Course @relation("RequiredBy", fields: [requiresCourseId], references: [id])

  @@unique([courseId, requiresCourseId])
}

model Curriculum {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curriculumCode    String             @unique
  name              String
  description       String?
  year              Int
  deptId            String             @db.Uuid
  facultyId         String             @db.Uuid
  status            CurriculumStatus   @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  department        Department         @relation(fields: [deptId], references: [id])
  faculty           Faculty            @relation(fields: [facultyId], references: [id])
  curriculumCourses CurriculumCourse[]
}

model CurriculumCourse {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curriculumId String     @db.Uuid
  courseId     String     @db.Uuid
  year         Int
  semester     Int
  positionX    Int
  positionY    Int
  course       Course     @relation(fields: [courseId], references: [id])
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])

  @@unique([curriculumId, courseId])
}

model Section {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String           @db.Uuid
  professorId   String           @db.Uuid
  sectionNo     Int
  capacity      Int
  enrolledCount Int              @default(0)
  academicYear  Int
  semester      Int
  enrollments   Enrollment[]
  course        Course           @relation(fields: [courseId], references: [id])
  professor     ProfessorProfile @relation(fields: [professorId], references: [userId])
}

model Enrollment {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String           @db.Uuid
  sectionId String           @db.Uuid
  status    EnrollmentStatus @default(SUCCESS)
  dropDate  DateTime?
  createdAt DateTime         @default(now())
  section   Section          @relation(fields: [sectionId], references: [id])
  student   StudentProfile   @relation(fields: [studentId], references: [userId])
}

model AcademicRecord {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String         @db.Uuid
  courseId     String         @db.Uuid
  academicYear Int
  semester     Int
  grade        String
  gradedById   String           @db.Uuid
  gradedBy     ProfessorProfile @relation(fields: [gradedById], references: [userId])
  course       Course           @relation(fields: [courseId], references: [id])
  student      StudentProfile   @relation(fields: [studentId], references: [userId])
}

model SemesterConfig {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYear Int
  semester     Int
  regStart     DateTime
  regEnd       DateTime
  withdrawEnd  DateTime
  isCurrent    Boolean  @default(false)
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId   String   @db.Uuid
  adminName String
  target    String
  action    Action
  createdAt DateTime @default(now())
  user      AdminProfile     @relation(fields: [adminId], references: [userId])
}

model Event {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    EventCategory @default(GENERAL)
}

enum Role {
  STUDENT
  PROFESSOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum StudentStatus {
  STUDYING
  GRADUATED
  RETIRED
}

enum CourseCategory {
  GENERAL_EDUCATION
  CORE_COURSE
  REQUIRED_COURSE
  MAJOR_ELECTIVE
  FREE_ELECTIVE
}

enum EnrollmentStatus {
  SUCCESS
  DROPPED
  WITHDRAWN
}

enum CurriculumStatus {
  ACTIVE
  INACTIVE
}

enum EventCategory {
  GENERAL
  ACADEMIC
  EXAM
  HOLIDAY
  ACTIVITY
}

enum Action {
  CREATE
  UPDATE
  DELETE
}
